{
	"gopls": {
		"buildFlags": ["-tags=!pgngen_debug"],
		"env": {
			"PGNGEN_DEBUG": "0"
		},
		"directoryFilters": ["-node_modules", "-/internal/pgn/pgn_debug_test.go"],
		"verboseOutput": true,
		"analyses": {
			"unusedparams": true,
			"shadow": true
		}
	},
	"go.testTags": "pgngen_debug",
	"go.lintTool": "golangci-lint-v2",
	"go.useLanguageServer": true,
	"go.formatFlags": ["fmt", "--stdin"],
	"go.formatTool": "custom",
	"go.alternateTools": {
		"golangci-lint-v2": "golangci-lint",
		"customFormatter": "golangci-lint"
	},
	"files.trimTrailingWhitespace": true,
	"editor.formatOnSave": true,
	"shellcheck.customArgs": ["-P", "SCRIPTDIR", "-x"],
	"[markdown]": {
		"editor.defaultFormatter": "dprint.dprint"
	},
	"[yaml]": {
		"editor.defaultFormatter": "redhat.vscode-yaml"
	}
}
