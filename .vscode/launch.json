    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Integration Test",
            "type": "go",
            "request": "launch",
            "mode": "test",
            "cwd": "${workspaceFolder}",
            "program": "${workspaceFolder}/pkg/node",
            "buildFlags": "-tags=integration",
            "args": [
                "-run=TestNodeIntegration"
